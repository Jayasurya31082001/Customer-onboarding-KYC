<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-kyc-cases-table" author="copilot">
        <createTable tableName="kyc_cases">
            <column name="kyc_case_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="document_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="provided_first_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="provided_last_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="provided_date_of_birth" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="kyc_cases" indexName="idx_kyc_cases_customer_id">
            <column name="customer_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="2-add-idempotency-key" author="copilot">
        <addColumn tableName="kyc_cases">
            <column name="idempotency_key" type="VARCHAR(128)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_kyc_cases_idempotency_key"/>
            </column>
        </addColumn>

        <createIndex tableName="kyc_cases" indexName="idx_kyc_cases_idempotency_key" unique="true">
            <column name="idempotency_key"/>
        </createIndex>
    </changeSet>

    <changeSet id="3-create-kyc-event-trigger-state" author="copilot">
        <createTable tableName="kyc_event_trigger_state">
            <column name="customer_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_registered_received" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="latest_document_id" type="UUID"/>
            <column name="last_started_document_id" type="UUID"/>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="kyc_event_trigger_state" indexName="idx_kyc_event_trigger_latest_document">
            <column name="latest_document_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="4-create-kyc-checks-table" author="copilot">
        <createTable tableName="kyc_checks">
            <column name="kyc_id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="result" type="VARCHAR(20)"/>
            <column name="provider_ref" type="VARCHAR(100)"/>
            <column name="risk_flags" type="CLOB"/>
            <column name="initiated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="kyc_checks" indexName="idx_customer_id">
            <column name="customer_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="5-add-index-updated-at-kyc-cases" author="data-sync-service">
        <createIndex tableName="kyc_cases" indexName="idx_kyc_cases_updated_at">
            <column name="updated_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
