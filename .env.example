# Environment Variables for Customer Onboarding KYC Platform

# ─── MySQL ─────────────────────────────────────────────────────────────────────
# Database password for local MySQL instance and Spring Boot microservices
DB_PASSWORD=Welcome@123

# Instructions to set/export DB_PASSWORD in your shell before starting microservices:
#
# PowerShell (Windows):
#   $env:DB_PASSWORD="Welcome@123"
#
# Command Prompt (Windows):
#   set DB_PASSWORD=Welcome@123
#
# Bash / Zsh (macOS / Linux):
#   export DB_PASSWORD=Welcome@123
#
# Using Docker Compose:
#   docker-compose up -d

# ─── Databricks (data-sync-service) ────────────────────────────────────────────
# Databricks workspace URL — copy from your Databricks workspace browser address bar
# Format: https://adb-<workspace-id>.<region>.azuredatabricks.net
DATABRICKS_WORKSPACE_URL=https://adb-xxxxxxxxxxxx.azuredatabricks.net

# Databricks Personal Access Token
# How to generate: Databricks UI → User Settings → Developer → Access tokens → Generate new token
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Internal Service Auth ─────────────────────────────────────────────────────
# Shared secret sent as X-Internal-Secret header on /internal/sync requests.
# Use a strong random string (min 32 chars) in production.
# Generate one: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=dev-internal-secret-change-in-prod

# ─── Sync Schedule Override (optional) ─────────────────────────────────────────
# Default: every 15 minutes. Uncomment and change to override.
# Cron format: second minute hour day month weekday
# DATASYNC_SCHEDULER_CRON=0 */15 * * * *
